apiVersion: v1
kind: Namespace
metadata:
  name: app
  labels:
    istio.io/deactivated: never-match
    istio.io/rev: default

---

apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx
  namespace: app
spec:
  replicas: 1
  selector:
    matchLabels:
      app: nginx
  template:
    metadata:
      labels:
        app: nginx
      annotations:
        sidecar.istio.io/inject: "true"
    spec:
      containers:
      - name: nginx
        image: nginx:1.29.6